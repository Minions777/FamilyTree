@import "../../../app.wxss";

.list-item {
  margin-top: 20rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f1f5f9;
}

.muted {
  margin-top: 8rpx;
  color: #6b7280;
}

.member-top {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e5e7eb;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-item {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 16rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #0f172a;
}

.distribution-row {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}
