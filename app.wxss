page {
  background: #f5f6fa;
  color: #1f2937;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-primary {
  background: #2563eb;
  color: #fff;
}

.btn-danger {
  background: #ef4444;
  color: #fff;
}

.tree-line {
  line-height: 1.8;
  margin-bottom: 8rpx;
  white-space: pre-wrap;
}

.field-label {
  margin: 12rpx 0 8rpx;
  color: #4b5563;
}

.input {
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
}
